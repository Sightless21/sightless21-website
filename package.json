{
	"name": "portfolio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.1.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@sveltejs/adapter-vercel": "^5.6.3",
		"@sveltejs/enhanced-img": "^0.6.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.1.8",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"mdsvex": "^0.12.6",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-check": "^4.4.6",
		"svelte-motion": "^0.12.2",
		"tailwindcss": "^4.1.8",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.2.6"
	},
	"dependencies": {
		"@inlang/paraglide-js": "^2.0.0",
		"@midudev/tailwind-animations": "^0.2.0",
		"@vercel/analytics": "^1.5.0",
		"@vercel/speed-insights": "^1.2.0",
		"clsx": "^2.1.1",
		"lucide-svelte": "^0.515.0",
		"svelte-inview": "^4.0.4",
		"svelte-vertical-timeline": "^2.0.0",
		"tailwind-merge": "^3.3.1"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./package/index.d.ts",
			"svelte": "./package/index.js",
			"default": "./package/index.js"
		},
		"./paraglide/.gitignore": "./package/paraglide/.gitignore",
		"./paraglide/.prettierignore": "./package/paraglide/.prettierignore",
		"./paraglide/README.md": "./package/paraglide/README.md",
		"./paraglide/messages/en": {
			"types": "./package/paraglide/messages/en.d.ts",
			"default": "./package/paraglide/messages/en.js"
		},
		"./paraglide/messages/ja": {
			"types": "./package/paraglide/messages/ja.d.ts",
			"default": "./package/paraglide/messages/ja.js"
		},
		"./paraglide/messages": {
			"types": "./package/paraglide/messages.d.ts",
			"default": "./package/paraglide/messages.js"
		},
		"./paraglide/registry": {
			"types": "./package/paraglide/registry.d.ts",
			"default": "./package/paraglide/registry.js"
		},
		"./paraglide/runtime": {
			"types": "./package/paraglide/runtime.d.ts",
			"default": "./package/paraglide/runtime.js"
		},
		"./paraglide/server": {
			"types": "./package/paraglide/server.d.ts",
			"default": "./package/paraglide/server.js"
		},
		"./transitions/flyFade": {
			"types": "./package/transitions/flyFade.d.ts",
			"default": "./package/transitions/flyFade.js"
		},
		"./utils/content": {
			"types": "./package/utils/content.d.ts",
			"default": "./package/utils/content.js"
		},
		"./utils/linkHelper": {
			"types": "./package/utils/linkHelper.d.ts",
			"default": "./package/utils/linkHelper.js"
		}
	},
	"files": [
		"package"
	],
	"typesVersions": {
		">4.0": {
			"index.d.ts": [
				"./package/index.d.ts"
			],
			"paraglide/messages/en": [
				"./package/paraglide/messages/en.d.ts"
			],
			"paraglide/messages/ja": [
				"./package/paraglide/messages/ja.d.ts"
			],
			"paraglide/messages": [
				"./package/paraglide/messages.d.ts"
			],
			"paraglide/registry": [
				"./package/paraglide/registry.d.ts"
			],
			"paraglide/runtime": [
				"./package/paraglide/runtime.d.ts"
			],
			"paraglide/server": [
				"./package/paraglide/server.d.ts"
			],
			"transitions/flyFade": [
				"./package/transitions/flyFade.d.ts"
			],
			"utils/content": [
				"./package/utils/content.d.ts"
			],
			"utils/linkHelper": [
				"./package/utils/linkHelper.d.ts"
			]
		}
	}
}